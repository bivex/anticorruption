Тест 14: оклад Голови НАЗК при мінімумі 3028 грн = 3028 × 40 = 121120.

```catala
scope TestNacpHead:
  definition result equals
    output of NacpSalary with {
      -- position: NacpPosition {
        -- is_head: true
        -- is_deputy_head: false
        -- is_apparatus_head: false
        -- is_territorial_head: false
        -- is_apparatus_deputy_head: false
        -- is_internal_control_head: false
        -- is_territorial_deputy_head: false
        -- is_department_head: false
        -- is_other: false
      }
      -- subsistence_min_jan1: $3,028.00
    }
  assertion result.base_salary = $121,120.00
```

